<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:models="using:Lumi.Models"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.AgentsView"
             x:DataType="vm:AgentsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <Style Selector="ScrollViewer.motion-surface, StackPanel.motion-surface">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer.motion-surface[IsVisible=true], StackPanel.motion-surface[IsVisible=true]">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.motion-action">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <BrushTransition Property="Background" Duration="0:0:0.12" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextTertiary}" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="LetterSpacing" Value="0.5" />
    </Style>

    <!-- Toggle pill -->
    <Style Selector="ToggleButton.pill">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderSubtle}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="Padding" Value="10,4,10,5" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextTertiary}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.15" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.15" />
          <BrushTransition Property="Foreground" Duration="0:0:0.15" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ToggleButton.pill:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.Surface2}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderDefault}" />
    </Style>
    <Style Selector="ToggleButton.pill:checked">
      <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtle}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentDefault}" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextPrimary}" />
    </Style>
    <Style Selector="ToggleButton.pill:checked:pointerover">
      <Setter Property="Background" Value="{DynamicResource Brush.AccentSubtleHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource Brush.AccentDefault}" />
    </Style>
  </UserControl.Styles>

  <Panel>
      <!-- Editor form -->
      <ScrollViewer Classes="motion-surface"
                    IsVisible="{Binding IsEditing}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="24,16,24,20">

          <!-- Header + actions row -->
          <DockPanel Margin="0,0,0,12">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button Classes="accent motion-action" Content="{loc:Str Common_Save}" Padding="18,7" MinHeight="0"
                      Command="{Binding SaveAgentCommand}" />
              <Button Classes="subtle motion-action" Content="{loc:Str Common_Cancel}" Padding="18,7" MinHeight="0"
                      Command="{Binding CancelEditCommand}" />
              <Button Classes="subtle motion-action" Padding="10,7" MinHeight="0"
                      Command="{Binding DeleteSelectedAgentCommand}"
                      IsVisible="{Binding SelectedAgent, Converter={x:Static ObjectConverters.IsNotNull}}"
                      ToolTip.Tip="{loc:Str Menu_Delete}">
                <PathIcon Data="{StaticResource Icon.Trash}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <StackPanel Spacing="2" VerticalAlignment="Center">
              <TextBlock Text="{loc:Str Editor_Lumi}" Classes="subtitle" />
              <TextBlock Text="{Binding SelectedAgentSharedSourceDisplay}"
                         FontSize="11"
                         Foreground="{DynamicResource Brush.AccentDefault}"
                         IsVisible="{Binding SelectedAgentSharedSourceDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
            </StackPanel>
          </DockPanel>

          <!-- Icon + Name row -->
          <DockPanel Margin="0,0,0,8">
            <Button x:Name="AgentIconPickerButton" DockPanel.Dock="Left" Classes="subtle" Margin="0,0,10,0"
                    Padding="0" MinHeight="0" MinWidth="0" CornerRadius="{DynamicResource Radius.Base}"
                    Width="36" Height="36" Cursor="Hand"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <sc:StrataIconPicker SelectedIcon="{Binding EditIconGlyph, Mode=TwoWay}"
                                       IconSelected="OnIconSelected" />
                </Flyout>
              </Button.Flyout>
              <TextBlock Text="{Binding EditIconGlyph, FallbackValue=✦}" FontSize="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <TextBox Text="{Binding EditName}" PlaceholderText="{loc:Str Watermark_AgentName}" />
          </DockPanel>

          <!-- Description -->
          <TextBox Text="{Binding EditDescription}" Margin="0,0,0,8"
                   PlaceholderText="{loc:Str Watermark_AgentDescription}" />

          <!-- System Prompt -->
          <TextBlock Text="{loc:Str Field_SystemPrompt}" Classes="field-label" />
          <TextBox Text="{Binding EditSystemPrompt}" AcceptsReturn="True" TextWrapping="Wrap"
                   MinHeight="68" MaxHeight="360"
                   VerticalContentAlignment="Top"
                   PlaceholderText="{loc:Str Watermark_AgentSystemPrompt}" />

          <Separator Margin="0,10,0,8" />

          <!-- Skills -->
          <TextBlock Text="{loc:Str Field_Skills}" Classes="section-label" />
          <ItemsControl ItemsSource="{Binding AvailableSkills}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:SkillToggle">
                <ToggleButton Classes="pill" IsChecked="{Binding IsSelected}"
                              ToolTip.Tip="{Binding Description}" Margin="0,0,6,6">
                  <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="{Binding IconGlyph}" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Font.SizeCaption}"
                               VerticalAlignment="Center" />
                  </StackPanel>
                </ToggleButton>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{loc:Str Agent_NoSkills}" Classes="caption tertiary"
                     IsVisible="{Binding !AvailableSkills.Count}" />

          <Separator Margin="0,6,0,8" />

          <!-- MCP Servers -->
          <TextBlock Text="{loc:Str Field_McpServers}" Classes="section-label" />
          <ItemsControl ItemsSource="{Binding AvailableMcpServers}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:McpServerToggle">
                <ToggleButton Classes="pill" IsChecked="{Binding IsSelected}" Margin="0,0,6,6">
                  <TextBlock Text="{Binding Name}" FontSize="{DynamicResource Font.SizeCaption}"
                             VerticalAlignment="Center" />
                </ToggleButton>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Text="{loc:Str Agent_NoMcpServers}" Classes="caption tertiary"
                     IsVisible="{Binding !AvailableMcpServers.Count}" />

          <Separator Margin="0,6,0,8" />

          <!-- Tools -->
          <TextBlock Text="{loc:Str Field_Tools}" Classes="section-label" />
          <ItemsControl ItemsSource="{Binding AvailableTools}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ToolToggle">
                <ToggleButton Classes="pill" IsChecked="{Binding IsSelected}"
                              ToolTip.Tip="{Binding Description}" Margin="0,0,6,6">
                  <TextBlock Text="{Binding DisplayName}" FontSize="{DynamicResource Font.SizeCaption}"
                             VerticalAlignment="Center" />
                </ToggleButton>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </ScrollViewer>

      <!-- Empty state -->
      <StackPanel Classes="motion-surface"
                  IsVisible="{Binding !IsEditing}"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" Opacity="0.4">
        <TextBlock Text="✦" FontSize="32" HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str Empty_SelectLumi}" FontSize="{DynamicResource Font.SizeBody}"
                   HorizontalAlignment="Center" />
      </StackPanel>
  </Panel>
</UserControl>
