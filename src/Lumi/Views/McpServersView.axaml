<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:sa="using:StrataTheme.Animation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:models="using:Lumi.Models"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.McpServersView"
             x:DataType="vm:McpServersViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <Style Selector="ScrollViewer.motion-surface, StackPanel.motion-surface">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer.motion-surface[IsVisible=true], StackPanel.motion-surface[IsVisible=true]">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.motion-action">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <sa:PremultipliedBrushTransition Property="Background" Duration="0:0:0.12" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </UserControl.Styles>

  <Panel>
      <!-- Editor form -->
      <ScrollViewer Classes="motion-surface"
                    IsVisible="{Binding IsEditing}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="24,20,24,28">

          <!-- Header + actions row -->
          <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button Classes="accent motion-action" Content="{loc:Str Common_Save}" Padding="18,7" MinHeight="0"
                      Command="{Binding SaveServerCommand}" />
              <Button Classes="subtle motion-action" Content="{loc:Str Common_Cancel}" Padding="18,7" MinHeight="0"
                      Command="{Binding CancelEditCommand}" />
              <Button Classes="subtle motion-action" Padding="10,7" MinHeight="0"
                      Command="{Binding DeleteServerCommand}"
                      CommandParameter="{Binding SelectedServer}"
                      IsVisible="{Binding SelectedServer, Converter={x:Static ObjectConverters.IsNotNull}}"
                      ToolTip.Tip="{loc:Str Menu_Delete}">
                <PathIcon Data="{StaticResource Icon.Trash}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <TextBlock Text="{loc:Str Editor_McpServer}" Classes="subtitle" VerticalAlignment="Center" />
          </DockPanel>

          <!-- Name -->
          <TextBlock Text="{loc:Str Field_Name}" Classes="field-label" />
          <TextBox Text="{Binding EditName}" PlaceholderText="{loc:Str Watermark_McpServerName}" Margin="0,0,0,10" />

          <!-- Description -->
          <TextBlock Text="{loc:Str Field_Description}" Classes="field-label" />
          <TextBox Text="{Binding EditDescription}" PlaceholderText="{loc:Str Watermark_McpServerDescription}" Margin="0,0,0,12" />

          <!-- Type + Enabled -->
          <sc:StrataSettingGroup>
            <sc:StrataSetting Header="Type" Description="Local (stdio) or Remote (SSE)">
              <ComboBox SelectedIndex="{Binding EditServerTypeIndex}" Width="160">
                <ComboBoxItem Content="{loc:Str McpType_Local}" />
                <ComboBoxItem Content="{loc:Str McpType_Remote}" />
              </ComboBox>
            </sc:StrataSetting>
            <sc:StrataSetting Header="Enabled" Description="Include in chat sessions">
              <ToggleSwitch IsChecked="{Binding EditIsEnabled}" OnContent="" OffContent="" />
            </sc:StrataSetting>
          </sc:StrataSettingGroup>

          <!-- Local server fields -->
          <StackPanel Spacing="0" IsVisible="{Binding !EditServerTypeIndex}">
            <Separator Margin="0,12,0,12" />

            <TextBlock Text="{loc:Str Field_Command}" Classes="field-label" />
            <TextBox Text="{Binding EditCommand}" PlaceholderText="{loc:Str Watermark_McpCommand}" Margin="0,0,0,10" />

            <!-- NPX package fields -->
            <StackPanel Spacing="0" IsVisible="{Binding IsNpxCommand}">
              <DockPanel Margin="0,0,0,4">
                <Button DockPanel.Dock="Right" Classes="subtle" Padding="8,3" MinHeight="0" CornerRadius="6"
                        Command="{Binding OpenNpmPageCommand}" ToolTip.Tip="Open npm page">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="{StaticResource Icon.Browse}" Width="11" Height="11"
                              Foreground="{DynamicResource Brush.TextTertiary}" />
                    <TextBlock Text="Docs" FontSize="11" Foreground="{DynamicResource Brush.TextTertiary}" />
                  </StackPanel>
                </Button>
                <TextBlock Text="Package" Classes="field-label" Margin="0" />
              </DockPanel>
              <TextBox Text="{Binding EditNpxPackage}" Margin="0,0,0,10"
                       PlaceholderText="@modelcontextprotocol/server-filesystem" />

                <TextBlock Text="{loc:Str Field_Arguments}" Classes="field-label" />
              <TextBox Text="{Binding EditServerArgs}" AcceptsReturn="True" TextWrapping="Wrap"
                       MinHeight="56" MaxHeight="200" VerticalContentAlignment="Top" Margin="0,0,0,10"
                       PlaceholderText="Paths, connection strings — one per line" />
            </StackPanel>

            <!-- Non-NPX arguments -->
            <StackPanel Spacing="0" IsVisible="{Binding !IsNpxCommand}">
              <TextBlock Text="{loc:Str Field_Arguments}" Classes="field-label" />
              <TextBox Text="{Binding EditArgs}" AcceptsReturn="True" TextWrapping="Wrap"
                       MinHeight="56" MaxHeight="200" VerticalContentAlignment="Top" Margin="0,0,0,10"
                       PlaceholderText="{loc:Str Watermark_McpArgs}" />
            </StackPanel>

            <!-- Environment Variables -->
            <TextBlock Text="{loc:Str Field_Environment}" Classes="field-label" />
            <TextBox Text="{Binding EditEnvVars}" AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="56" MaxHeight="200" VerticalContentAlignment="Top"
                     PlaceholderText="API_KEY=your-key  (one per line)" />
          </StackPanel>

          <!-- Remote server fields -->
          <StackPanel Spacing="0" IsVisible="{Binding EditServerTypeIndex}">
            <Separator Margin="0,12,0,12" />

            <TextBlock Text="{loc:Str Field_Url}" Classes="field-label" />
            <TextBox Text="{Binding EditUrl}" PlaceholderText="{loc:Str Watermark_McpUrl}" Margin="0,0,0,10" />

            <TextBlock Text="{loc:Str Field_Headers}" Classes="field-label" />
            <TextBox Text="{Binding EditHeaders}" AcceptsReturn="True" TextWrapping="Wrap"
                     MinHeight="56" MaxHeight="200" VerticalContentAlignment="Top"
                     PlaceholderText="Authorization=Bearer token" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- Browse catalog (unchanged) -->
      <DockPanel IsVisible="{Binding IsBrowsing}">
        <StackPanel DockPanel.Dock="Top" Spacing="1" Margin="24,20,24,0">
          <TextBlock Text="{loc:Str Mcp_BrowseCatalog}" Classes="subtitle" />
          <TextBlock Text="Discover and install MCP servers from npm"
                     Classes="caption tertiary" />
        </StackPanel>

        <Border DockPanel.Dock="Top" Margin="24,12,24,0">
          <TextBox PlaceholderText="{loc:Str Mcp_SearchCatalog}" Text="{Binding BrowseSearchQuery}"
                   Padding="8,7,10,7" FontSize="{DynamicResource Font.SizeBody}">
            <TextBox.InnerLeftContent>
              <PathIcon Data="{StaticResource Icon.Search}" Width="13" Height="13"
                        Foreground="{DynamicResource Brush.TextTertiary}" Margin="6,0,4,0" />
            </TextBox.InnerLeftContent>
          </TextBox>
        </Border>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6"
                    IsVisible="{Binding IsSearchingNpm}" Margin="24,8,24,0">
          <TextBlock Text="⏳" FontSize="{DynamicResource Font.SizeCaption}"
                     Foreground="{DynamicResource Brush.TextTertiary}">
            <TextBlock.Styles>
              <Style Selector="TextBlock">
                <Style.Animations>
                  <Animation Duration="0:0:0.8" IterationCount="Infinite"
                             PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
                    <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
                  </Animation>
                </Style.Animations>
              </Style>
            </TextBlock.Styles>
          </TextBlock>
          <TextBlock Text="{loc:Str Mcp_SearchingNpm}" Classes="caption tertiary" />
        </StackPanel>

        <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto"
                      Margin="24,12,24,20">
          <ItemsControl ItemsSource="{Binding CatalogEntries}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:McpCatalogEntry">
                <Border Background="{DynamicResource Brush.SurfaceSubtle}"
                        CornerRadius="{DynamicResource Radius.Base}" Padding="14,12" Margin="0,0,0,6"
                        BorderBrush="{DynamicResource Brush.BorderSubtle}" BorderThickness="1">
                  <Border.Transitions>
                    <Transitions><BrushTransition Property="BorderBrush" Duration="0:0:0.15" /></Transitions>
                  </Border.Transitions>
                  <Border.Styles>
                    <Style Selector="Border:pointerover">
                      <Setter Property="BorderBrush" Value="{DynamicResource Brush.BorderDefault}" />
                    </Style>
                  </Border.Styles>
                  <DockPanel>
                    <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="12,0,0,0"
                            Padding="14,6" MinHeight="0" CornerRadius="8"
                            IsEnabled="{Binding !IsInstalled}"
                            Command="{Binding $parent[UserControl].((vm:McpServersViewModel)DataContext).InstallCatalogEntryCommand}"
                            CommandParameter="{Binding}">
                      <Button.Styles>
                        <Style Selector="Button:disabled"><Setter Property="Opacity" Value="0.6" /></Style>
                      </Button.Styles>
                      <StackPanel Orientation="Horizontal" Spacing="5">
                        <PathIcon Data="{StaticResource Icon.Check}" Width="11" Height="11" IsVisible="{Binding IsInstalled}" />
                        <TextBlock Text="{loc:Str Mcp_Install}" IsVisible="{Binding !IsInstalled}" FontWeight="Medium" />
                        <TextBlock Text="{loc:Str Mcp_Installed}" IsVisible="{Binding IsInstalled}" />
                      </StackPanel>
                    </Button>
                    <StackPanel Spacing="3">
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding Icon}" FontSize="16" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Background="{DynamicResource Brush.SurfaceRaised}" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                          <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}" FontWeight="Medium" />
                        </Border>
                      </StackPanel>
                      <TextBlock Text="{Binding Description}" Classes="caption" Foreground="{DynamicResource Brush.TextSecondary}"
                                 TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                      <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding NpmPackage}" FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}"
                                   FontFamily="Consolas,Menlo,monospace" Opacity="0.7" />
                        <TextBlock Text="{Binding DownloadsDisplay}" FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}"
                                   IsVisible="{Binding MonthlyDownloads}" />
                      </StackPanel>
                      <StackPanel Orientation="Horizontal" Spacing="4" IsVisible="{Binding HasRequiredEnvVars}">
                        <TextBlock Text="🔑" FontSize="10" VerticalAlignment="Center" />
                        <TextBlock Text="Requires:" FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding EnvVarHint}" FontSize="10" Foreground="{DynamicResource Brush.TextTertiary}"
                                   FontFamily="Consolas,Menlo,monospace" />
                      </StackPanel>
                    </StackPanel>
                  </DockPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </DockPanel>

      <!-- Empty state -->
      <StackPanel Classes="motion-surface"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10" Opacity="0.35">
        <StackPanel.IsVisible>
          <MultiBinding Converter="{x:Static BoolConverters.And}">
            <Binding Path="!IsEditing" />
            <Binding Path="!IsBrowsing" />
          </MultiBinding>
        </StackPanel.IsVisible>
        <PathIcon Data="{StaticResource Icon.Plug}" Width="28" Height="28"
                  Foreground="{DynamicResource Brush.TextSecondary}" HorizontalAlignment="Center" />
        <StackPanel Spacing="2" HorizontalAlignment="Center">
          <TextBlock Text="{loc:Str Empty_SelectMcpServer}" HorizontalAlignment="Center" />
          <TextBlock Text="Select a server or browse the catalog" Classes="caption tertiary"
                     HorizontalAlignment="Center" />
        </StackPanel>
      </StackPanel>
  </Panel>
</UserControl>
