<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:sa="using:StrataTheme.Animation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:models="using:Lumi.Models"
             xmlns:sc="using:StrataTheme.Controls"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.SkillsView"
             x:DataType="vm:SkillsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <Style Selector="ScrollViewer.motion-surface, StackPanel.motion-surface">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer.motion-surface[IsVisible=true], StackPanel.motion-surface[IsVisible=true]">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.motion-action">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <sa:PremultipliedBrushTransition Property="Background" Duration="0:0:0.12" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>
  </UserControl.Styles>

  <Panel>
      <!-- Editor form -->
      <ScrollViewer Classes="motion-surface"
                    IsVisible="{Binding IsEditing}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="24,20,24,28">

          <!-- Header + actions row -->
          <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button Classes="accent motion-action" Content="{loc:Str Common_Save}" Padding="18,7" MinHeight="0"
                      Command="{Binding SaveSkillCommand}" />
              <Button Classes="subtle motion-action" Content="{loc:Str Common_Cancel}" Padding="18,7" MinHeight="0"
                      Command="{Binding CancelEditCommand}" />
              <Button Classes="subtle motion-action" Padding="10,7" MinHeight="0"
                      Command="{Binding DeleteSkillCommand}"
                      CommandParameter="{Binding SelectedSkill}"
                      IsVisible="{Binding SelectedSkill, Converter={x:Static ObjectConverters.IsNotNull}}"
                      ToolTip.Tip="{loc:Str Menu_Delete}">
                <PathIcon Data="{StaticResource Icon.Trash}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <TextBlock Text="{loc:Str Editor_Skill}" Classes="subtitle" VerticalAlignment="Center" />
          </DockPanel>

          <!-- Icon + Name row -->
          <DockPanel Margin="0,0,0,10">
            <Button x:Name="SkillIconPickerButton" DockPanel.Dock="Left" Classes="subtle" Margin="0,0,10,0"
                    Padding="0" MinHeight="0" MinWidth="0" CornerRadius="{DynamicResource Radius.Base}"
                    Width="36" Height="36" Cursor="Hand"
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
              <Button.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <sc:StrataIconPicker SelectedIcon="{Binding EditIconGlyph, Mode=TwoWay}"
                                       IconSelected="OnIconSelected" />
                </Flyout>
              </Button.Flyout>
              <TextBlock Text="{Binding EditIconGlyph, FallbackValue=⚡}" FontSize="18"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Button>
            <TextBox Text="{Binding EditName}" PlaceholderText="{loc:Str Watermark_SkillName}" />
          </DockPanel>

          <!-- Description -->
          <TextBox Text="{Binding EditDescription}" Margin="0,0,0,14"
                   PlaceholderText="{loc:Str Watermark_SkillDescription}" />

          <!-- Instructions -->
          <TextBlock Text="{loc:Str Field_Instructions}" Classes="field-label" />
          <TextBox Text="{Binding EditContent}" AcceptsReturn="True" TextWrapping="Wrap"
                   MinHeight="200" MaxHeight="480"
                   VerticalContentAlignment="Top"
                   PlaceholderText="{loc:Str Watermark_SkillInstructions}" />

        </StackPanel>
      </ScrollViewer>

      <!-- Empty state -->
      <StackPanel Classes="motion-surface"
                  IsVisible="{Binding !IsEditing}"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" Opacity="0.4">
        <TextBlock Text="⚡" FontSize="32" HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str Empty_SelectSkill}" FontSize="{DynamicResource Font.SizeBody}"
                   HorizontalAlignment="Center" />
      </StackPanel>
  </Panel>
</UserControl>
