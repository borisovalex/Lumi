<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:sa="using:StrataTheme.Animation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Lumi.ViewModels"
             xmlns:models="using:Lumi.Models"
             xmlns:loc="using:Lumi.Localization"
             x:Class="Lumi.Views.ProjectsView"
             x:DataType="vm:ProjectsViewModel"
             x:CompileBindings="True">

  <UserControl.Styles>
    <Style Selector="ScrollViewer.motion-surface, StackPanel.motion-surface">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="ScrollViewer.motion-surface[IsVisible=true], StackPanel.motion-surface[IsVisible=true]">
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Button.motion-action">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <sa:PremultipliedBrushTransition Property="Background" Duration="0:0:0.12" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.motion-list-row">
      <Setter Property="Opacity" Value="0.95" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
          <sa:PremultipliedBrushTransition Property="Background" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Button.motion-list-row:pointerover">
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="TextBlock.field-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextSecondary}" />
      <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <Style Selector="TextBlock.section-label">
      <Setter Property="FontSize" Value="{DynamicResource Font.SizeCaption}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource Brush.TextTertiary}" />
      <Setter Property="Margin" Value="0,0,0,6" />
      <Setter Property="LetterSpacing" Value="0.5" />
    </Style>
  </UserControl.Styles>

  <Panel>
      <!-- Editor form -->
      <ScrollViewer Classes="motion-surface"
                    IsVisible="{Binding IsEditing}"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="0" Margin="24,20,24,28">

          <!-- Header + actions row -->
          <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <Button Classes="accent motion-action" Content="{loc:Str Common_Save}" Padding="18,7" MinHeight="0"
                      Command="{Binding SaveProjectCommand}" />
              <Button Classes="subtle motion-action" Content="{loc:Str Common_Cancel}" Padding="18,7" MinHeight="0"
                      Command="{Binding CancelEditCommand}" />
              <Button Classes="subtle motion-action" Padding="10,7" MinHeight="0"
                      Command="{Binding DeleteProjectCommand}"
                      CommandParameter="{Binding SelectedProject}"
                      IsVisible="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}"
                      ToolTip.Tip="{loc:Str Menu_Delete}">
                <PathIcon Data="{StaticResource Icon.Trash}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <TextBlock Text="{loc:Str Editor_Project}" Classes="subtitle" VerticalAlignment="Center" />
          </DockPanel>

          <!-- Name -->
          <TextBlock Text="{loc:Str Field_Name}" Classes="field-label" />
          <TextBox Text="{Binding EditName}" PlaceholderText="{loc:Str Watermark_ProjectName}" Margin="0,0,0,10" />

          <!-- Working Directory -->
          <TextBlock Text="{loc:Str Field_WorkingDirectory}" Classes="field-label" />
          <DockPanel Margin="0,0,0,2">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
              <Button Name="BrowseFolderButton" Classes="subtle motion-action" Padding="8,6" MinHeight="0"
                      CornerRadius="6" ToolTip.Tip="{loc:Str Project_Browse}">
                <PathIcon Data="{StaticResource Icon.Folder}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
              <Button Classes="subtle motion-action" Padding="8,6" MinHeight="0" CornerRadius="6"
                      Command="{Binding ClearWorkingDirectoryCommand}"
                      IsVisible="{Binding EditWorkingDirectory, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Clear">
                <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <TextBox Text="{Binding EditWorkingDirectory}" PlaceholderText="{loc:Str Watermark_ProjectWorkingDir}" />
          </DockPanel>

          <!-- Coding project indicator -->
          <StackPanel Orientation="Horizontal" Spacing="6"
                      IsVisible="{Binding IsCodingProject}" Margin="0,2,0,0">
            <TextBlock Text="💻" FontSize="12" VerticalAlignment="Center" />
            <TextBlock Text="{loc:Str Project_CodingProjectDetected}"
                       FontSize="{DynamicResource Font.SizeCaption}"
                       Foreground="{DynamicResource Brush.AccentDefault}"
                       VerticalAlignment="Center" />
          </StackPanel>

          <!-- Additional context folders -->
          <DockPanel Margin="0,12,0,4">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="4" Margin="8,0,0,0">
              <Button Name="BrowseAdditionalFoldersButton" Classes="subtle motion-action" Padding="8,6" MinHeight="0"
                      CornerRadius="6" ToolTip.Tip="{loc:Str Project_AddFolders}">
                <PathIcon Data="{StaticResource Icon.Folder}" Width="14" Height="14"
                          Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
              <Button Classes="subtle motion-action" Padding="8,6" MinHeight="0" CornerRadius="6"
                      Command="{Binding ClearAdditionalContextDirectoriesCommand}"
                      IsVisible="{Binding EditAdditionalContextDirectories, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"
                      ToolTip.Tip="Clear">
                <TextBlock Text="✕" FontSize="12" Foreground="{DynamicResource Brush.TextTertiary}" />
              </Button>
            </StackPanel>
            <StackPanel Spacing="2">
              <TextBlock Text="{loc:Str Field_AdditionalContextFolders}" Classes="field-label" Margin="0" />
              <TextBlock Text="{loc:Str Project_AdditionalContextFoldersHint}"
                         Classes="caption tertiary"
                         TextWrapping="Wrap" />
            </StackPanel>
          </DockPanel>
          <TextBox Text="{Binding EditAdditionalContextDirectories}"
                   AcceptsReturn="True"
                   TextWrapping="NoWrap"
                   MinHeight="62"
                   MaxHeight="140"
                   VerticalContentAlignment="Top"
                   PlaceholderText="{loc:Str Watermark_ProjectAdditionalContextDirs}" />

          <!-- Instructions -->
          <TextBlock Text="{loc:Str Field_Instructions}" Classes="field-label" Margin="0,12,0,4" />
          <TextBox Text="{Binding EditInstructions}" AcceptsReturn="True" TextWrapping="Wrap"
                   MinHeight="100" MaxHeight="360" VerticalContentAlignment="Top"
                   PlaceholderText="{loc:Str Watermark_ProjectInstructions}" />

          <!-- Chats in this project -->
          <StackPanel IsVisible="{Binding SelectedProject, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Separator Margin="0,16,0,12" />
            <TextBlock Text="{loc:Str Field_Chats}" Classes="section-label" />

            <Border IsVisible="{Binding !ProjectChats.Count}"
                    Background="{DynamicResource Brush.SurfaceRaised}" CornerRadius="{DynamicResource Radius.Base}"
                    Padding="16,14">
              <StackPanel Spacing="4" HorizontalAlignment="Center" Opacity="0.5">
                <PathIcon Data="{StaticResource Icon.Chat}" Width="18" Height="18" HorizontalAlignment="Center" />
                <TextBlock Text="{loc:Str Empty_NoProjectChats}" Classes="caption" HorizontalAlignment="Center" />
              </StackPanel>
            </Border>

            <ItemsControl ItemsSource="{Binding ProjectChats}" IsVisible="{Binding ProjectChats.Count}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="models:Chat" x:CompileBindings="False">
                  <Button Classes="subtle motion-list-row" HorizontalAlignment="Stretch"
                          HorizontalContentAlignment="Left"
                          Padding="8,7" MinHeight="0" Margin="0,1"
                          CornerRadius="{DynamicResource Radius.Base}"
                          Command="{Binding $parent[UserControl].DataContext.OpenChatCommand}"
                          CommandParameter="{Binding}">
                    <DockPanel>
                      <TextBlock DockPanel.Dock="Right" FontSize="{DynamicResource Font.SizeCaption}"
                                 Foreground="{DynamicResource Brush.TextTertiary}"
                                 VerticalAlignment="Center" Margin="12,0,0,0"
                                 Text="{Binding UpdatedAt, StringFormat='{}{0:MMM d}'}" />
                      <PathIcon DockPanel.Dock="Left" Data="{StaticResource Icon.Chat}"
                                Width="13" Height="13" VerticalAlignment="Center"
                                Foreground="{DynamicResource Brush.TextTertiary}" Margin="0,0,8,0" />
                      <TextBlock Text="{Binding Title}" FontSize="{DynamicResource Font.SizeBody}"
                                 TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    </DockPanel>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </StackPanel>
      </ScrollViewer>

      <!-- Empty state -->
      <StackPanel Classes="motion-surface"
                  IsVisible="{Binding !IsEditing}"
                  HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="6" Opacity="0.4">
        <TextBlock Text="📁" FontSize="32" HorizontalAlignment="Center" />
        <TextBlock Text="{loc:Str Empty_SelectProject}" FontSize="{DynamicResource Font.SizeBody}"
                   HorizontalAlignment="Center" />
      </StackPanel>
  </Panel>
</UserControl>
