<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:chrome="using:Avalonia.Controls.Chrome"
             x:Class="Lumi.App"
             RequestedThemeVariant="Dark">

  <Application.Resources>
    <ResourceDictionary>
      <!-- Lumi-local override of Strata's glass-surface token. The presence field sits BEHIND the
           translucent islands, so the island fill is the only readability substrate between the chat
           text and whatever is on the desktop behind the (transparent) window. Strata's stock opacity
           is tuned for benign backdrops; over a bright/busy backdrop (white docs etc.) it lets too much
           through and text gets hard to read. We firm the islands up here (less transparency) — and the
           presence light is boosted in PresenceController to keep blooming through the thicker glass.
           Dark is Lumi's default; HighContrast intentionally falls through to Strata's already-solid value. -->
      <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Dark">
          <SolidColorBrush x:Key="Brush.Surface1Glass" Color="{DynamicResource Color.Surface1}" Opacity="0.72" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
          <SolidColorBrush x:Key="Brush.Surface1Glass" Color="{DynamicResource Color.Surface1}" Opacity="0.78" />
        </ResourceDictionary>
      </ResourceDictionary.ThemeDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <SimpleTheme />
    <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Simple.xaml" />
    <StyleInclude Source="avares://StrataTheme/StrataTheme.axaml" />

    <!-- Hide the fullscreen button from drawn window decorations (added by Simple theme) -->
    <Style Selector="Button#PART_FullScreenButton">
      <Setter Property="IsVisible" Value="False" />
    </Style>

    <!-- Make drawn decorations fully transparent so acrylic/mica blur shows through -->
    <Style Selector="WindowDrawnDecorations">
      <Setter Property="DefaultShadowThickness" Value="0" />
      <Setter Property="DefaultFrameThickness" Value="0" />
    </Style>
    <Style Selector="WindowDrawnDecorations /template/ Border#PART_WindowBorder">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="BoxShadow" Value="0 0 0 0 Transparent" />
    </Style>
    <Style Selector="WindowDrawnDecorations /template/ Panel#PART_TitleBar">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="WindowDrawnDecorations /template/ Panel#PART_UnderlayWrapper">
      <Setter Property="IsVisible" Value="False" />
    </Style>
  </Application.Styles>

</Application>
