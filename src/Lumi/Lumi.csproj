<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationIcon>Assets\lumi-icon.ico</ApplicationIcon>
    <Version>0.9.2</Version>

    <!-- Publishing -->
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <PublishTrimmed>true</PublishTrimmed>
    <TrimMode>partial</TrimMode>
    <DebugType>none</DebugType>

    <!-- .NET 11 Runtime Async -->
    <EnablePreviewFeatures>true</EnablePreviewFeatures>
    <Features>$(Features);runtime-async=on</Features>
    <NoWarn>$(NoWarn);GHCP001</NoWarn>
    <!-- Pin the bundled Copilot CLI version so new models and reliability fixes are available. -->
    <CopilotCliVersion>1.0.64</CopilotCliVersion>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Lumi.Tests" />
  </ItemGroup>

  <!-- Windows: target Windows TFM so WinRT toast types are available in-process -->
  <PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
    <TargetFramework>net11.0-windows10.0.22621.0</TargetFramework>
  </PropertyGroup>
  <PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
    <TargetFramework>net11.0</TargetFramework>
  </PropertyGroup>

  <ItemGroup>
    <AvaloniaResource Include="Assets\lumi-icon.png" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="Resources\Strings\*.json" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="12.0.5" />
    <PackageReference Include="Avalonia.Desktop" Version="12.0.5" />
    <PackageReference Include="Avalonia.Themes.Simple" Version="12.0.5" />
    <PackageReference Include="Avalonia.Controls.DataGrid" Version="12.0.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="FlaUI.UIA3" Version="4.0.0" />
    <PackageReference Include="GitHub.Copilot.SDK" Version="1.0.1" />
    <PackageReference Include="StreamJsonRpc" Version="2.25.29" />
    <PackageReference Include="Microsoft.Toolkit.Uwp.Notifications" Version="7.1.3" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.5" />
    <!-- Override the transitive SQLitePCLRaw.bundle_e_sqlite3 2.1.10 (vulnerable SQLite < 3.50.2, CVE-2025-6965 / GHSA-2m69-gcr7-jv3q).
         3.0.x ships the patched native binary via SourceGear.sqlite3. -->
    <PackageReference Include="SQLitePCLRaw.bundle_e_sqlite3" Version="3.0.3" />
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.3124.44" />
    <PackageReference Include="System.Drawing.Common" Version="9.0.5" />
    <PackageReference Include="Velopack" Version="0.0.1298" />
    <PackageReference Include="AvaloniaMcp.Diagnostics" Version="0.4.0" Condition="'$(Configuration)' == 'Debug'" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Lumi.Generators\Lumi.Generators.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
    <ProjectReference Include="..\..\Strata\src\StrataSearch\StrataSearch.csproj" />
    <ProjectReference Include="..\..\Strata\src\StrataTheme\StrataTheme.csproj" />
  </ItemGroup>

  <!-- Exclude test harness from Release builds -->
  <ItemGroup Condition="'$(Configuration)' != 'Debug'">
    <Compile Remove="OnboardingAgentTest.cs" />
    <Compile Remove="DebugAgentHarness.cs" />
    <Compile Remove="Services\LumiDebugBridge.cs" />
    <Compile Remove="ViewModels\ChatViewModel.Debug.cs" />
    <Compile Remove="UiPerf\UiResponsivenessProbe.cs" />
    <Compile Remove="UiPerf\UiWorkloadScenarios.cs" />
    <Compile Remove="UiPerf\UiResponsivenessHarness.cs" />
    <Compile Remove="UiPerf\UiStreamingLoad.cs" />
    <!-- UiHarnessOptions/UiResponsivenessMetrics/UiResponsivenessReport are intentionally NOT removed:
         they are pure-logic, side-effect-free types that the Lumi.Tests project references, and
         pr-validation.yml builds AND runs the whole solution in Release config. Removing them would
         break the Release test compile. They are unreachable from production code (every caller in
         Program.cs/App is #if DEBUG), so they are inert dead code in the shipped app. -->
  </ItemGroup>

</Project>
